# =============================================================================
# 2D Dynamic Rupture Simulation — Input File (Rate-and-State)
# Runner: python3 rupture_2d.py input/rupture_2d_RS.in
# =============================================================================


# -----------------------------------------------------------------------------
# OUTPUT CONTROL
# -----------------------------------------------------------------------------

output_prefix = rupture_2d_RS
iplot = 5


# -----------------------------------------------------------------------------
# DOMAIN GEOMETRY
# -----------------------------------------------------------------------------

Lx = 10.0
Ly = 20.0


# -----------------------------------------------------------------------------
# GRID
# -----------------------------------------------------------------------------

nx = 26
ny = 51


# -----------------------------------------------------------------------------
# MATERIAL PROPERTIES
# -----------------------------------------------------------------------------

cp = 6.0
cs = 3.464
rho = 2.6702


# -----------------------------------------------------------------------------
# TIME STEPPING
# -----------------------------------------------------------------------------

cfl = 0.5
tend = 10.0


# -----------------------------------------------------------------------------
# NUMERICAL SCHEME
# -----------------------------------------------------------------------------

order = 6


# -----------------------------------------------------------------------------
# FRACTURE MODE
# -----------------------------------------------------------------------------

mode = II


# -----------------------------------------------------------------------------
# FRICTION LAW
# -----------------------------------------------------------------------------

fric_law = RS


# -----------------------------------------------------------------------------
# NUCLEATION PATCH CENTER (km along fault)
# Default: [10.0]
# -----------------------------------------------------------------------------

Y0 = 10.0


# -----------------------------------------------------------------------------
# POINT SOURCE  (M0=0 disables)
# -----------------------------------------------------------------------------

x0 = -15.0
y0 = 7.5
t0 = 0.0
T = 0.1
M0 = 0.0


# -----------------------------------------------------------------------------
# BOUNDARY CONDITIONS
# [x_outer, x_fault, y_bottom, y_top]   0=absorbing  1=free-surface
# -----------------------------------------------------------------------------

r_l_0 = 0.
r_l_1 = 0.
r_l_2 = 1.
r_l_3 = 0.

r_r_0 = 0.
r_r_1 = 0.
r_r_2 = 1.
r_r_3 = 0.


# -----------------------------------------------------------------------------
# RATE-AND-STATE (RS) FRICTION PARAMETERS
# Velocity-weakening requires b > a.
# Nucleation is driven by a Gaussian stress perturbation (25 MPa peak)
# centred at Y0 applied over the first 1 s — handled inside rate2d.py.
# -----------------------------------------------------------------------------

# Background shear traction (MPa).  Default: [75.0]
Tau_0_RS = 75.0

# Reference friction coefficient.  Default: [0.6]
f0 = 0.6

# Direct effect.  Default: [0.008]
a = 0.008

# Evolution effect.  b > a for velocity-weakening.  Default: [0.012]
b = 0.012

# Reference slip velocity (m/s).  Default: [1.0e-6]
V0 = 1.0e-6

# State evolution distance (m).  Default: [0.02]
L0 = 0.02

# Initial state variable.  Default: [0.4367]
psi_init = 0.4367

# Normal stress magnitude (MPa, positive = compressive).  Default: [120.0]
sigma_n_RS = 120.0

# Initial slip velocity for steady-state psi estimate (m/s).  Default: [2.0e-12]
Vin = 2.0e-12


# -----------------------------------------------------------------------------
# SW PARAMETERS (unused for RS — kept for completeness)
# -----------------------------------------------------------------------------

Tau_0_SW = 81.6
alp_s = 0.677
alp_d = 0.525
D_c = 0.4
sigma_n = 120.0
