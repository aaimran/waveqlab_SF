\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The 1D rupture model. Two elastic blocks are separated by a fault at $x = L = 15\,\text  {km}$. During rupture, the left side slides one way and the right side the other. Outgoing waves are absorbed at the ends so reflections do not contaminate the solution.}}{6}{figure.caption.8}\protected@file@percent }
\newlabel{fig:geometry}{{2}{6}{The 1D rupture model. Two elastic blocks are separated by a fault at $x = L = 15\,\text {km}$. During rupture, the left side slides one way and the right side the other. Outgoing waves are absorbed at the ends so reflections do not contaminate the solution}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}Fault Friction: The Slip-Weakening Law}{6}{subsection.2.4}\protected@file@percent }
\newlabel{eq:sw}{{1}{6}{Fault Friction: The Slip-Weakening Law}{equation.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces The four friction parameters that define a rupture scenario. These are the inputs to the FNO.}}{7}{table.caption.9}\protected@file@percent }
\newlabel{tab:params}{{2}{7}{The four friction parameters that define a rupture scenario. These are the inputs to the FNO}{table.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The slip-weakening friction law. As the fault slides from $D=0$ to $D=D_c$, the friction coefficient drops linearly from the static value $\alpha _s$ to the dynamic value $\alpha _d$. A larger strength drop ($\alpha _s - \alpha _d$) produces more violent rupture. A smaller $D_c$ means the fault weakens over a shorter distance, allowing faster acceleration.}}{7}{figure.caption.10}\protected@file@percent }
\newlabel{fig:sw_diagram}{{3}{7}{The slip-weakening friction law. As the fault slides from $D=0$ to $D=D_c$, the friction coefficient drops linearly from the static value $\alpha _s$ to the dynamic value $\alpha _d$. A larger strength drop ($\alpha _s - \alpha _d$) produces more violent rupture. A smaller $D_c$ means the fault weakens over a shorter distance, allowing faster acceleration}{figure.caption.10}{}}
