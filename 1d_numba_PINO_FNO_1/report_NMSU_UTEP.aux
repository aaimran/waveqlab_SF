\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Schematic outputs of the simulator. \textbf  {Left}: the velocity field $v_l(x,t)$ shows a wavefront travelling at $c_s \approx 3.46$ km/s. \textbf  {Right}: the slip-rate history at the fault peaks sharply then decays — this is the ``pulse'' of the earthquake. The FNO must learn to reproduce both from just 4 numbers.}}{8}{figure.caption.11}\protected@file@percent }
\newlabel{fig:sim_output}{{4}{8}{Schematic outputs of the simulator. \textbf {Left}: the velocity field $v_l(x,t)$ shows a wavefront travelling at $c_s \approx 3.46$ km/s. \textbf {Right}: the slip-rate history at the fault peaks sharply then decays — this is the ``pulse'' of the earthquake. The FNO must learn to reproduce both from just 4 numbers}{figure.caption.11}{}}
