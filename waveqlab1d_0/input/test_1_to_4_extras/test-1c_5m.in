# Withers et al. (2015) Figure 3 — Elastic half-space
# VS=3464 m/s, rho=2700 kg/m3, infinite Q
# r0_l=0, r1_r=0 + PML (5 km, 1000 nodes at 5m)
response = elastic
cfl      = 0.5
L        = 30.0
nx       = 6001
cs       = 3.464
rho      = 2.700
tend     = 8.0
fric_law = SW
Tau_0     = 81.60
sigma_n   = 120.0
alp_s     = 0.677
alp_d     = 0.525
D_c       = 0.4
slip_init = 0.0
order    = 6
w_stride = 1
output_prefix = test-1c_5m

r0_l = 0
r1_r = 0

pml       = true
npml      = 1000
pml_alpha = 10.0
