# =============================================================================
# 2D Dynamic Rupture Simulation — Input File (Slip-Weakening)
# Runner: python3 rupture_2d.py input/rupture_2d_SW.in
#
# FORMAT:  key = value
#   - Lines starting with # are comments (ignored)
#   - Blank lines are ignored
#   - Any key below can be omitted to use the built-in default (shown in [])
# =============================================================================


# -----------------------------------------------------------------------------
# OUTPUT CONTROL
# -----------------------------------------------------------------------------

output_prefix = rupture_2d_SW

# Snapshot stride: store domain fields every `iplot` time steps.
# Larger values reduce memory of DomainOutput arrays.
# Default: [5]
iplot = 5


# -----------------------------------------------------------------------------
# DOMAIN GEOMETRY
# -----------------------------------------------------------------------------

# Half-domain length in x (km).
# Fault is at x=0.  Left domain: x in [-Lx, 0].  Right domain: x in [0, Lx].
# Default: [10.0]
Lx = 10.0

# Domain length along fault in y (km).
# Default: [20.0]
Ly = 20.0


# -----------------------------------------------------------------------------
# GRID
# -----------------------------------------------------------------------------

# Grid points in x per domain (vertex-centred: last node at fault x=0).
# Default: [26]
nx = 101

# Grid points in y (vertex-centred: nodes at y=0 and y=Ly).
# Default: [51]
ny = 201


# -----------------------------------------------------------------------------
# MATERIAL PROPERTIES  (homogeneous, identical both domains)
# -----------------------------------------------------------------------------

# P-wave velocity (km/s).  Default: [6.0]
cp = 6.0

# S-wave velocity (km/s).  Default: [3.464]
cs = 3.464

# Density (g/cm^3).  Default: [2.6702]
rho = 2.6702


# -----------------------------------------------------------------------------
# TIME STEPPING
# -----------------------------------------------------------------------------

# CFL number.  dt = cfl / sqrt(cp^2 + cs^2) * dx.  Default: [0.5]
cfl = 0.5

# Simulation end time (s).  Default: [10.0]
tend = 10.0


# -----------------------------------------------------------------------------
# NUMERICAL SCHEME
# -----------------------------------------------------------------------------

# SBP operator order of accuracy.  Available: 2, 4, 6.  Default: [6]
order = 6


# -----------------------------------------------------------------------------
# FRACTURE MODE
# Mode II  — in-plane shear (P+S waves): fields [vx, vy, sxx, syy, sxy]
# Mode III — anti-plane shear (S wave only): fields [vz, sxz, syz]
# Default: [II]
# -----------------------------------------------------------------------------
mode = II


# -----------------------------------------------------------------------------
# FRICTION LAW
# Available: SW (slip-weakening)  RS (rate-and-state)
# Default: [SW]
# -----------------------------------------------------------------------------
fric_law = SW


# -----------------------------------------------------------------------------
# NUCLEATION PATCH
# Center of the nucleation perturbation along the fault (km).
# Default: [10.0]  — fault midpoint for Ly=20
# -----------------------------------------------------------------------------
Y0 = 10.0


# -----------------------------------------------------------------------------
# POINT SOURCE  (set M0=0 to disable)
# -----------------------------------------------------------------------------

# Source location (km).  Default: x0=[-15.0], y0=[7.5]
x0 = -15.0
y0 = 7.5

# Source onset time (s).  Default: [0.0]
t0 = 0.0

# Source duration (s).  Default: [0.1]
T = 0.1

# Source amplitude (MPa).  Set 0 to disable.  Default: [0.0]
M0 = 0.0


# -----------------------------------------------------------------------------
# BOUNDARY CONDITIONS
# Each domain has 4 boundaries: [x_outer, x_fault, y_bottom, y_top]
#   0  = absorbing
#   1  = free-surface
#  -1  = clamped
# -----------------------------------------------------------------------------

# Left domain boundary conditions
r_l_0 = 0.
r_l_1 = 0.
r_l_2 = 1.
r_l_3 = 0.

# Right domain boundary conditions
r_r_0 = 0.
r_r_1 = 0.
r_r_2 = 1.
r_r_3 = 0.


# -----------------------------------------------------------------------------
# SLIP-WEAKENING (SW) FRICTION PARAMETERS
# Used only when fric_law = SW
#
# Tau_0_SW: background shear traction (MPa).
#   Nucleation patch gets +11.6 * Y_fault added (where Y_fault=1 within 1.5 km
#   of Y0), so the patch traction = Tau_0_SW + 11.6 = 81.6 MPa (= alp_s*sigma_n).
#   Background value must be 70.0. Default: [70.0]
# -----------------------------------------------------------------------------

Tau_0_SW = 70.0

# Static (peak) friction coefficient.  Default: [0.677]
alp_s = 0.677

# Dynamic (residual) friction coefficient.  Must be < alp_s.  Default: [0.525]
alp_d = 0.525

# Critical slip distance (m).  Default: [0.4]
D_c = 0.4

# Normal stress magnitude (MPa, positive = compressive).  Default: [120.0]
sigma_n = 120.0


# -----------------------------------------------------------------------------
# RATE-AND-STATE (RS) FRICTION PARAMETERS
# Used only when fric_law = RS
# (These are ignored for SW but kept here for reference)
# -----------------------------------------------------------------------------

# Background shear traction (MPa).  Default: [75.0]
Tau_0_RS = 75.0

# Reference friction coefficient at V0.  Default: [0.6]
f0 = 0.6

# Direct effect.  Default: [0.008]
a = 0.008

# Evolution effect.  Velocity-weakening requires b > a.  Default: [0.012]
b = 0.012

# Reference slip velocity (m/s).  Default: [1.0e-6]
V0 = 1.0e-6

# State evolution distance (m).  Default: [0.02]
L0 = 0.02

# Initial state variable psi_0.  Default: [0.4367]
psi_init = 0.4367

# Normal stress magnitude (MPa) for RS.  Default: [120.0]
sigma_n_RS = 120.0

# Initial slip velocity for RS steady-state psi computation (m/s).
# Default: [2.0e-12]
Vin = 2.0e-12
